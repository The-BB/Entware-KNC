#!/bin/sh

ENABLED=yes

DESC="BB applet crond"
PROCS="crond"
PROG="/opt/sbin/$PROCS"

PID_FILE="/opt/var/run/$PROCS.pid"

start_pre() {
  rm -f "PID_FILE"
  [ -d "/opt/var/spool/cron/crontabs" ] || \
  mkdir -pm 0750 /opt/var/spool/cron/crontabs
}

PRECMD="start_pre"
ARGS=""
PREARGS=""

. /opt/etc/init.d/rc.func
