+/* ILA_ATTR_IDENT_TYPE/ILA_ATTR_HOOK_TYPE since Linux 4.15 */
+	#if LINUX_VERSION_CODE <= KERNEL_VERSION(4,15,0)
 	[ILA_ATTR_IDENT_TYPE] = { .type = NLA_U8 },
 	[ILA_ATTR_HOOK_TYPE] = { .type = NLA_U8 },
