@@ -147,6 +159,7 @@ static int ila_encap_parse_msg(struct nl
 		if (err < 0)
 			return err;
 	}
+	#endif /* ILA_ATTR_IDENT_TYPE/ILA_ATTR_HOOK_TYPE since Linux 4.15 */
 
